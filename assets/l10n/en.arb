    "description": "Surfaced for 5xx responses (ServerException).",
    "placeholders": { "statusCode": { "type": "int", "example": "503" } }
  },
  "errorNetwork": "No internet connection. Check your network and try again.",
  "@errorNetwork": {
    "description": "Surfaced when the transport reports a connection error (NetworkException)."
  },
  "errorTimeout": "The connection took too long. Please try again.",
  "@errorTimeout": {
    "description": "Surfaced when a request times out (TimeoutException)."
  },
  "errorHttp": "Server error (HTTP {statusCode}). Please try again later.",
  "@errorHttp": {
    "description": "Fallback for an HttpException whose status code didn't map to a more specific DomainException.",
    "placeholders": { "statusCode": { "type": "int", "example": "418" } }
  },
  "errorParse": "Unexpected response from the server.",
  "@errorParse": {
    "description": "Surfaced when the response body fails to parse (ParseException)."
  },
  "errorUnknownData": "An unknown error occurred. Please try again.",
  "@errorUnknownData": {
    "description": "Catch-all for UnknownDataException."
  },
  "errorGeneric": "Something went wrong. Please try again.",
